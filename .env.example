# ─── Supabase (required for cloud sync + invite links) ─────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Google Sign-In (required for Google auth) ──────────────────────────────
# Get this from: Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─── Anthropic Claude AI (optional — enables receipt scan + AI advisor) ─────
# Get this from: https://console.anthropic.com/settings/api-keys
# Set in: Vercel Dashboard → Project → Settings → Environment Variables
# When set: "Scan Receipt" button appears in Add Expense dialog (uses Claude Vision)
#           "Explain my plan 🤖" button appears in Goals tab (uses Claude Haiku)
# Security note: VITE_ prefix exposes the key to the browser bundle. This is
#   intentional and uses the anthropic-dangerous-direct-browser-access header.
#   Rotate the key if you suspect exposure. Do not grant it write-level permissions.
VITE_ANTHROPIC_API_KEY=sk-ant-...

# ─── Resend email (server-side only — never use VITE_ prefix) ──────────────
# Used by: api/send-invite.ts (Vercel serverless function only)
# Get this from: https://resend.com/api-keys
# Set in: Vercel Dashboard → Project → Settings → Environment Variables
RESEND_API_KEY=re_...

# ─── Notes ──────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# The app works fully offline without any of these — Supabase, Google, and
# email features are progressively enhanced (graceful no-ops when not set).
#
# NEVER commit .env.local — it is already in .gitignore.
# NEVER put RESEND_API_KEY in a VITE_ variable — it would be in the browser bundle.
